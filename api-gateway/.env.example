# Environment Configuration
NODE_ENV=development
PORT=3000

# Service URLs
AUTH_SERVICE_URL=http://localhost:4001
PATIENT_SERVICE_URL=http://localhost:4002
DOCTOR_SERVICE_URL=http://localhost:4003
APPOINTMENT_SERVICE_URL=http://localhost:4004
AI_SERVICE_URL=http://localhost:4005
NOTIFICATION_SERVICE_URL=http://localhost:4006
SEARCH_SERVICE_URL=http://localhost:4007

# JWT Configuration
JWT_ACCESS_SECRET=fallback_access_secret
JWT_REFRESH_SECRET=your-refresh-secret-here

# CORS
CORS_ORIGIN=http://localhost:19006,http://localhost:3001

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_MAX=5
GRAPHQL_RATE_LIMIT_MAX=200

# Circuit Breaker
CIRCUIT_BREAKER_TIMEOUT=3000
CIRCUIT_BREAKER_ERROR_THRESHOLD=50
CIRCUIT_BREAKER_RESET_TIMEOUT=30000

# Cache
CACHE_TTL=300
CACHE_CHECK_PERIOD=600

# Service Timeouts (ms)
SERVICE_TIMEOUT=5000
PROXY_TIMEOUT=10000

# GraphQL
GRAPHQL_INTROSPECTION=true
GRAPHQL_PLAYGROUND=true

# Logging
LOG_LEVEL=info
