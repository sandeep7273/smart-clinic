# ─────────────────────────────────────────────
# API Gateway — Environment Variables Example
# Copy to .env and fill in real values.
# NEVER commit .env to version control.
# In production, use AWS Secrets Manager + SSM Parameter Store.
# ─────────────────────────────────────────────

# Server
NODE_ENV=development          # development | production
PORT=3000
SERVICE_NAME=api-gateway
SERVICE_VERSION=1.0.0

# Internal Service URLs (use ECS Service Connect DNS in production)
AUTH_SERVICE_URL=http://localhost:4001
# Production: http://auth-service.smartclinic.local:4001
DOCTOR_SERVICE_URL=http://localhost:4002
# Production: http://doctor-service.smartclinic.local:4002
APPOINTMENT_SERVICE_URL=http://localhost:4003
# Production: http://appointment-service.smartclinic.local:4003
AI_SERVICE_URL=http://localhost:4004
# Production: http://ai-service.smartclinic.local:4004

# JWT (must match auth-service; use Secrets Manager in production)
JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_base64_32

# Internal service-to-service auth token (use Secrets Manager in production)
INTERNAL_SERVICE_TOKEN=CHANGE_ME_generate_with_openssl_rand_base64_32

# CORS (comma-separated list of allowed origins)
CORS_ORIGIN=http://localhost:19006,http://localhost:8081,http://localhost:5173

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000   # 15 minutes
RATE_LIMIT_MAX_REQUESTS=60
AUTH_RATE_LIMIT_MAX=5
GRAPHQL_RATE_LIMIT_MAX=100

# Circuit Breaker
CIRCUIT_BREAKER_TIMEOUT=10000
CIRCUIT_BREAKER_ERROR_THRESHOLD=60
CIRCUIT_BREAKER_RESET_TIMEOUT=60000

# Cache
CACHE_TTL=300
CACHE_CHECK_PERIOD=600

# Timeouts (ms)
SERVICE_TIMEOUT=5000
PROXY_TIMEOUT=10000

# GraphQL
GRAPHQL_INTROSPECTION=true    # set false in production
GRAPHQL_PLAYGROUND=true       # set false in production

# Observability
OTLP_ENDPOINT=http://localhost:4318   # OTel Collector endpoint
LOG_LEVEL=info                        # debug | info | warn | error
