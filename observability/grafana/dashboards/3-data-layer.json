{
  "uid": "smartclinic-datalayer",
  "title": "3 — Data Layer Health",
  "description": "MongoDB, Redis, Kafka — connection pools, query times, consumer lag",
  "tags": ["smartclinic", "database", "kafka", "redis"],
  "timezone": "browser",
  "refresh": "30s",
  "time": { "from": "now-3h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "MongoDB — Active Connections (per service)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "mongodb_connections_current",
          "legendFormat": "{{service}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "MongoDB — Operations / sec",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "fieldConfig": { "defaults": { "unit": "ops" } },
      "targets": [
        {
          "expr": "rate(mongodb_op_counters_total[1m])",
          "legendFormat": "{{type}}"
        }
      ]
    },
    {
      "id": 3,
      "title": "Redis — Hit Rate % (AI Service cache)",
      "description": "Cache hit rate below 60% means Redis isn't helping. Check TTL settings.",
      "type": "gauge",
      "gridPos": { "x": 0, "y": 8, "w": 6, "h": 6 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "steps": [
              { "color": "red", "value": 0 },
              { "color": "yellow", "value": 0.6 },
              { "color": "green", "value": 0.8 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "redis_keyspace_hits_total / (redis_keyspace_hits_total + redis_keyspace_misses_total)",
          "legendFormat": "Hit Rate"
        }
      ]
    },
    {
      "id": 4,
      "title": "Redis — Memory Used (MB)",
      "type": "timeseries",
      "gridPos": { "x": 6, "y": 8, "w": 6, "h": 6 },
      "fieldConfig": { "defaults": { "unit": "decmbytes" } },
      "targets": [
        {
          "expr": "redis_memory_used_bytes / 1024 / 1024",
          "legendFormat": "Memory MB"
        }
      ]
    },
    {
      "id": 5,
      "title": "Redis — Connected Clients",
      "type": "stat",
      "gridPos": { "x": 12, "y": 8, "w": 6, "h": 6 },
      "targets": [
        {
          "expr": "redis_connected_clients",
          "legendFormat": "Clients"
        }
      ]
    },
    {
      "id": 6,
      "title": "Redis — Operations / sec",
      "type": "timeseries",
      "gridPos": { "x": 18, "y": 8, "w": 6, "h": 6 },
      "fieldConfig": { "defaults": { "unit": "ops" } },
      "targets": [
        {
          "expr": "rate(redis_commands_processed_total[1m])",
          "legendFormat": "Commands / s"
        }
      ]
    },
    {
      "id": 7,
      "title": "Kafka — Consumer Lag (appointment-service)",
      "description": "Lag > 1000 triggers an alarm and scales the Appointment Service.",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 14, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 100 },
              { "color": "red", "value": 1000 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "kafka_consumer_group_lag",
          "legendFormat": "{{topic}} — {{consumer_group}}"
        }
      ]
    },
    {
      "id": 8,
      "title": "Kafka — Messages Produced / sec",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 14, "w": 12, "h": 8 },
      "fieldConfig": { "defaults": { "unit": "msgs" } },
      "targets": [
        {
          "expr": "rate(kafka_producer_record_send_total[1m])",
          "legendFormat": "{{topic}}"
        }
      ]
    }
  ]
}
