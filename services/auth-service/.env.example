# ─────────────────────────────────────────────
# Auth Service — Environment Variables Example
# Copy to .env and fill in real values.
# NEVER commit .env to version control.
# In production, use AWS Secrets Manager + SSM Parameter Store.
# ─────────────────────────────────────────────

# Server
NODE_ENV=development          # development | production
PORT=4001
SERVICE_NAME=auth-service
SERVICE_VERSION=1.0.0

# MongoDB (use Secrets Manager in production)
MONGODB_URI=mongodb://localhost:27017/auth_db
MONGODB_TEST_URI=mongodb://localhost:27017/auth_db_test

# JWT (use Secrets Manager in production — must be 256-bit random string)
JWT_ACCESS_SECRET=CHANGE_ME_generate_with_openssl_rand_base64_32
JWT_REFRESH_SECRET=CHANGE_ME_generate_with_openssl_rand_base64_32
JWT_ISSUER=auth-service
ACCESS_TOKEN_EXPIRY=500m
REFRESH_TOKEN_EXPIRY=7d

# CORS (comma-separated list of allowed origins)
# Production (ECS): include the ALB and S3 frontend URLs
CORS_ORIGIN=http://localhost:3000,http://localhost:8081,http://localhost:19006
# CORS_ORIGIN=http://smartclinic-dev-alb-1797412677.ap-south-1.elb.amazonaws.com,http://smartclinic-web-ui-791732163161-aps1.s3-website.ap-south-1.amazonaws.com

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000   # 15 minutes
RATE_LIMIT_MAX_REQUESTS=1000

# Kafka (use SSM Parameter Store in production)
KAFKA_BROKERS=localhost:9092
# KAFKA_SASL_USERNAME=          # for MSK SASL
# KAFKA_SASL_PASSWORD=          # use Secrets Manager in production

# Observability
OTLP_ENDPOINT=http://localhost:4318   # OTel Collector endpoint
LOG_LEVEL=info                        # debug | info | warn | error
