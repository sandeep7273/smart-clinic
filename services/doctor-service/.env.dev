NODE_ENV=development
PORT=4003
GRPC_PORT=50051
SERVICE_NAME=doctor-service

# ── MongoDB — Atlas (same data as ECS, includes seeded doctors) ─
MONGODB_URI=mongodb+srv://sandiipkd_db_user:DSmCA0vOYaOSG0Al@cluster0.lr0lbks.mongodb.net/doctor_db?appName=Cluster0

# ── API Gateway URL ───────────────────────────────────────────
