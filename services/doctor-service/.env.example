# ───────────────────────────────────────────────
# Doctor Service — Environment Variables Example
# Copy to .env and fill in real values.
# NEVER commit .env to version control.
# In production, use AWS Secrets Manager + SSM Parameter Store.
# ───────────────────────────────────────────────

# Server
NODE_ENV=development          # development | production
PORT=4002
SERVICE_NAME=doctor-service
SERVICE_VERSION=1.0.0

# MongoDB (use Secrets Manager in production)
MONGODB_URI=mongodb://localhost:27017/doctor_db

# gRPC Server (consumed by Appointment Service and AI Service)
GRPC_PORT=50051

# Kafka (use SSM Parameter Store in production)
KAFKA_BROKERS=localhost:9092
# KAFKA_SASL_USERNAME=
# KAFKA_SASL_PASSWORD=          # use Secrets Manager in production

# CORS
CORS_ORIGIN=http://localhost:3000

# API Gateway (for internal reference / token validation fallback)
API_GATEWAY_URL=http://localhost:3000
# Production (ECS Service Connect): API_GATEWAY_URL=http://api-gateway.smartclinic.local:3000

# Observability
OTLP_ENDPOINT=http://localhost:4318   # OTel Collector endpoint
LOG_LEVEL=info                        # debug | info | warn | error
