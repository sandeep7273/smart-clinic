# ─────────────────────────────────────────────────────────────
# AI Service — LOCAL DEVELOPMENT environment
# Used by: docker-compose.dev.yml
# ─────────────────────────────────────────────────────────────

NODE_ENV=development
PORT=4005
SERVICE_NAME=ai-service

# ── MongoDB — Atlas (same data as ECS) ──────────────────────
MONGODB_URI=mongodb+srv://sandiipkd_db_user:DSmCA0vOYaOSG0Al@cluster0.lr0lbks.mongodb.net/ai_db?appName=Cluster0

# ── Redis — local container ───────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ── Groq LLM ──────────────────────────────────────────────────
GROQ_API_KEY=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
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_MAX_TOKENS=1000
GROQ_TEMPERATURE=0.7

# ── ChromaDB ──────────────────────────────────────────────────
CHROMA_HOST=localhost
CHROMA_PORT=8000
CHROMA_COLLECTION_NAME=medical_knowledge

# ── Internal gRPC addresses ───────────────────────────────────
DOCTOR_SERVICE_GRPC_HOST=doctor-service
DOCTOR_SERVICE_GRPC_PORT=50051
APPOINTMENT_SERVICE_GRPC_HOST=appointment-service
APPOINTMENT_SERVICE_GRPC_PORT=50052

# ── API Gateway URL ───────────────────────────────────────────
API_GATEWAY_URL=http://api-gateway:3000

# ── Context / Rate Limiting ───────────────────────────────────
MAX_CONTEXT_MESSAGES=10
CONTEXT_TTL=3600
RATE_LIMIT_WINDOW=60000
RATE_LIMIT_MAX_REQUESTS=1000

# ── Cache TTL ─────────────────────────────────────────────────
CACHE_TTL_DOCTOR_SEARCH=300
CACHE_TTL_APPOINTMENT=180

# ── Logging ───────────────────────────────────────────────────
LOG_LEVEL=debug
