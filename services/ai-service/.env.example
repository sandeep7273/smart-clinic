# ─────────────────────────────────────────────
# AI Service — Environment Variables Example
# Copy to .env and fill in real values.
# NEVER commit .env to version control.
# In production, use AWS Secrets Manager + SSM Parameter Store.
# ─────────────────────────────────────────────

# Server
NODE_ENV=development          # development | production
PORT=4004
SERVICE_NAME=ai-service
SERVICE_VERSION=1.0.0

# MongoDB (use Secrets Manager in production)
MONGODB_URI=mongodb://localhost:27017/ai_db

# Redis / ElastiCache (use Secrets Manager for password in production)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=               # leave empty for local dev
REDIS_DB=0

# Groq LLM API (use Secrets Manager in production — never hardcode)
GROQ_API_KEY=CHANGE_ME
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_MAX_TOKENS=1000
GROQ_TEMPERATURE=0.7

# ChromaDB (vector store for RAG)
CHROMA_HOST=localhost
CHROMA_PORT=8000
CHROMA_COLLECTION_NAME=medical_knowledge

# Doctor Service gRPC
DOCTOR_SERVICE_GRPC_HOST=localhost
DOCTOR_SERVICE_GRPC_PORT=50051
# Production: doctor-service.smartclinic.local

# Appointment Service gRPC
APPOINTMENT_SERVICE_GRPC_HOST=localhost
APPOINTMENT_SERVICE_GRPC_PORT=50052
# Production: appointment-service.smartclinic.local

# API Gateway (for token validation)
API_GATEWAY_URL=http://localhost:3000
# Production (ECS Service Connect): API_GATEWAY_URL=http://api-gateway.smartclinic.local:3000

# Context / Rate Limiting
MAX_CONTEXT_MESSAGES=10
CONTEXT_TTL=3600              # seconds
RATE_LIMIT_WINDOW=60000       # ms
RATE_LIMIT_MAX_REQUESTS=100

# Cache TTL
CACHE_TTL_DOCTOR_SEARCH=300   # seconds

# Observability
OTLP_ENDPOINT=http://localhost:4318   # OTel Collector endpoint
LOG_LEVEL=info                        # debug | info | warn | error
