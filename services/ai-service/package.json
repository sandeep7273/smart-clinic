{
  "name": "ai-service",
  "version": "1.0.0",
  "description": "AI Chat Assistant with Intent Detection, RAG, and Context Memory",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "seed:embeddings": "node src/scripts/seedEmbeddings.js",
