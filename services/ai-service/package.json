    "test:ci": "jest --ci --passWithNoTests",
    "lint": "eslint src/",
    "format": "prettier --write \"src/**/*.js\""
  },
  "keywords": [
    "ai",
    "chatbot",
    "healthcare",
    "rag",
    "intent-detection",
    "llm",
    "grpc"
  ],
  "author": "",
  "license": "ISC",
