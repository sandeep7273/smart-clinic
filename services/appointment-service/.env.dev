# ─────────────────────────────────────────────────────────────
# Appointment Service — LOCAL DEVELOPMENT environment
# Used by: docker-compose.dev.yml
# ─────────────────────────────────────────────────────────────

NODE_ENV=development
PORT=4004
GRPC_PORT=50052
SERVICE_NAME=appointment-service

# ── MongoDB — Atlas (same data as ECS) ──────────────────────
MONGO_URI=mongodb+srv://sandiipkd_db_user:DSmCA0vOYaOSG0Al@cluster0.lr0lbks.mongodb.net/appointment_service?appName=Cluster0

# ── API Gateway URL ───────────────────────────────────────────
API_GATEWAY_URL=http://api-gateway:3000

# ── Kafka ─────────────────────────────────────────────────────
KAFKA_BROKERS=kafka:9092

# ── CORS ──────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:3000,http://localhost:5173,http://api-gateway:3000

# ── Doctor Service gRPC ───────────────────────────────────────
DOCTOR_GRPC_URL=doctor-service:50051

# ── Logging ───────────────────────────────────────────────────
LOG_LEVEL=debug
