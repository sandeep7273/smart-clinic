###############################################################################
# Smart Clinic — Root .gitignore
# Covers: Node.js, React/Vite, React Native, Terraform, Docker, macOS, IDEs
###############################################################################

# ── Node.js ───────────────────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
.npm
.yarn-integrity

# ── Environment / Secrets — NEVER COMMIT ─────────────────────────────────────
.env
.env.local
.env.dev
.env.*.local
.env.development
.env.production
.env.staging
.env.test

# Service-specific env files (contain real credentials)
.env.auth
.env.gateway
.env.doctor
.env.appointment
.env.ai

# Allow: .env.example files (no real secrets)
!.env.example
!.env.*.example

# ── Logs ──────────────────────────────────────────────────────────────────────
logs/
*.log
logs
pids/
*.pid
*.pid.lock

# ── Build Outputs ─────────────────────────────────────────────────────────────
dist/
dist-ssr/
build/
out/
.output/
.nuxt/
.next/

# ── Test & Coverage ───────────────────────────────────────────────────────────
coverage/
.nyc_output/
*.lcov
junit.xml
test-results/
test-output.txt

# ── Terraform ─────────────────────────────────────────────────────────────────
**/.terraform/
**/.terraform.lock.hcl
**/terraform.tfstate
**/terraform.tfstate.backup
**/terraform.tfstate.*.backup
**/tfplan
**/plan-output.txt

# terraform.tfvars files contain real secrets — never commit
**/terraform.tfvars
**/terraform.tfvars.json
# Allow: example tfvars
!**/terraform.tfvars.example

# ── Docker ────────────────────────────────────────────────────────────────────
# Keep Dockerfiles and docker-compose files; ignore local overrides
docker-compose.override.yml
.docker/

# ── React Native / iOS ────────────────────────────────────────────────────────
# iOS
mobile_ui_app/ios/build/
mobile_ui_app/ios/DerivedData/
mobile_ui_app/ios/**/*.xcuserstate
mobile_ui_app/ios/**/*.xcworkspace/xcuserdata/
mobile_ui_app/ios/Pods/
mobile_ui_app/ios/.xcode.env.local

# Android
mobile_ui_app/android/build/
mobile_ui_app/android/app/build/
mobile_ui_app/android/.gradle/
mobile_ui_app/android/local.properties
mobile_ui_app/android/*.keystore
mobile_ui_app/android/app/*.keystore
!mobile_ui_app/android/debug.keystore
!mobile_ui_app/android/app/debug.keystore
mobile_ui_app/android/app/.cxx/
**/.cxx/
mobile_ui_app/android/.kotlin/

# React Native Metro
.metro-health-check*

# Ruby / CocoaPods (mobile)
mobile_ui_app/ios/Pods/
mobile_ui_app/vendor/bundle/
**/Pods/

# Fastlane artifacts
**/fastlane/report.xml
**/fastlane/Preview.html
**/fastlane/screenshots/
**/fastlane/test_output/

# React Native bundle
*.jsbundle
*.jsbundle.map

# ── Web UI (React/Vite) ───────────────────────────────────────────────────────
web_ui_app/dist/
web_ui_app/.env.development
web_ui_app/.env.production
web_ui_app/.vite/

# ── macOS ─────────────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
.AppleDouble
.LSOverride

# ── Windows ───────────────────────────────────────────────────────────────────
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# ── IDE / Editor ──────────────────────────────────────────────────────────────
.vscode/
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp
*.swo
*~
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace

# ── Misc ──────────────────────────────────────────────────────────────────────
tmp/
temp/
*.tmp
*.bak
*.orig
.cache/
.parcel-cache/
.eslintcache
.stylelintcache

# Sentry / sourcemaps
*.map
!*.css.map
!*.js.map

# Certificates / Keys — extra safety
*.pem
*.key
*.p12
*.pfx
*.crt
*.cer
!*example*.pem
!*example*.key

