          "response": []
        },
        {
          "name": "register",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    const res = pm.response.json();",
                  "    if (res.data) {",
                  "        pm.collectionVariables.set('accessToken', res.data.accessToken);",
                  "        pm.collectionVariables.set('refreshToken', res.data.refreshToken);",
                  "        if (res.data.user) {",
                  "            pm.collectionVariables.set('userId', res.data.user._id || res.data.user.id);",
                  "        }",
                  "    }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"Jane\",\n  \"lastName\": \"Doe\",\n  \"email\": \"jane.doe@example.com\",\n  \"password\": \"Password123\",\n  \"phoneNumber\": \"+1-555-0101\",\n  \"dateOfBirth\": \"1990-05-15\"\n}",
